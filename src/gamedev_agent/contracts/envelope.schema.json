{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gamedev-agent.local/contracts/envelope.schema.json",
  "title": "GameDevAgent protocol envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "kind", "request_id", "payload"],
  "properties": {
    "schema_version": {"const": 1},
    "kind": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
    },
    "request_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "payload": {"type": "object"}
  }
}
